# Database Configuration (REQUIRED - no defaults for security)
DB_NAME=call_center_qa
DB_USER=postgres
DB_PASS=your_secure_password_here
DB_HOST=db
DB_PORT=5432

# Local vLLM Inference Configuration
LOCAL_LLM_API_BASE=http://vllm:8899/v1
LOCAL_LLM_MODEL=hugging-quants/Meta-Llama-3.1-8B-Instruct-AWQ-INT4

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key
JWT_REFRESH_SECRET=your_super_secret_refresh_key

# Default Admin (for first startup)
DEFAULT_ADMIN_PASSWORD=admin123
